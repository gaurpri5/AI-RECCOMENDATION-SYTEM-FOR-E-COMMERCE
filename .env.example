# Copy this file to .env and fill in your actual values
# DO NOT commit .env file with actual secrets to version control

# Firebase Configuration (for admin SDK if needed)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Firebase Web API Config (for Pyrebase Auth)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_SENDER_ID=your_firebase_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_DATABASE_URL=

# Razorpay Keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Groq API for AI Chatbot
GROQ_API_KEY=your_groq_api_key_here

# Reflex Deployment (set automatically by deployment platforms)
REFLEX_API_URL=http://127.0.0.1:8000